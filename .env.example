# Provider keys are optional for local development/tests.
# When LLM_ENABLE_LIVE_CALLS=false (default), the API uses a deterministic classifier path
# so pytest/demo/eval stay stable without network calls.
#
# Set LLM_ENABLE_LIVE_CALLS=true when you want real LiteLLM provider chaining.
LLM_ENABLE_LIVE_CALLS=false

# GOOGLE_API_KEY=
# CLAUDE_API_KEY=
# OPENAI_API_KEY=
