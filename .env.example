# At least one key is needed once LLM integration is implemented.
# Minimal bootstrap does not call providers yet.
# Live provider calls are opt-in for deterministic local tests.
# Set to true when you want real LLM provider chaining.
LLM_ENABLE_LIVE_CALLS=false

